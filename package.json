{
  "name": "jack-campus-social",
  "version": "1.0.0",
  "description": "校园社交网站 - 包含社交功能和食堂系统",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:web": "cd frontend && npm run dev",
    "dev:app": "cd frontend-app && npm run dev",
    "import-products": "node scripts/bulk-import-products.js",
    "migrate:all": "node scripts/run-migrations-all.js",
    "migrate:admin": "node scripts/apply-sql-file.js migrations/056_admin_system.sql && node scripts/apply-sql-file.js migrations/057_user_status.sql",
    "migrate:square": "node scripts/run-migrations-041-045.js",
    "migrate:title": "node scripts/run-migration-013-title.js",
    "migrate:title:railway": "node scripts/migrate-railway-013-posts-title-safe.js",
    "migrate:perf:railway": "node scripts/migrate-railway-014-perf-indexes-safe.js",
    "backfill:post-thumbs": "node scripts/backfill-post-thumbs.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "build:web": "cd frontend && npm run build",
    "build:app": "cd frontend-app && npm run build",
    "build:capacitor": "cd frontend-app && npx vite build --base=./ --mode capacitor",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android"
  },
  "keywords": [
    "campus",
    "social",
    "canteen"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.888.0",
    "@capacitor/android": "^8.4.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jpush-phonegap-plugin": "^6.0.3",
    "jsonwebtoken": "^9.0.2",
    "ms": "^2.1.3",
    "multer": "^2.1.1",
    "mysql2": "^3.6.5",
    "nodemailer": "^8.0.2",
    "sanitize-html": "^2.17.1",
    "sharp": "^0.34.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "@jest/globals": "^30.4.1",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3"
  }
}
