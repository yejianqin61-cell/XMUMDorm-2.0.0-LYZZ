# ========== 数据库（二选一）==========
# 本地：只填下面 DB_*，DB_NAME 一般为 jack_campus；不要填 MYSQL_URL，否则会连到云上。
# 云上 / Railway：填 DATABASE_URL 或 MYSQL_URL（库名在链接末尾，常见为 .../railway）。
# 若同时存在 MYSQL_URL 与 DB_NAME：迁移脚本以「连接串里的库名」为准，避免误连到不存在的 jack_campus。
# PORT=4040
# NODE_ENV=development
# JWT_SECRET=请改为随机长串
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=jack_campus
# DATABASE_URL=
# MYSQL_URL=

# Object Storage (S3 compatible): Cloudflare R2 / AWS S3 / COS / OSS
# Public read is recommended via bucket policy + CDN.
# 重要：商品/帖子等图片上传到对象存储后，接口用此地址生成图片 URL。
# 本地开发也必须配置此项，否则返回 /uploads/xxx 会访问本地静态目录（无文件），图片 404 看不到。
PUBLIC_ASSET_BASE_URL=https://pub-62ee299bb18a4fb0a9819dd8a73a8603.r2.dev
OBJECT_STORAGE_ENDPOINT=https://9bcb1de061419f70838c6e2b3957ed7c.r2.cloudflarestorage.com/jack-dorm-assets
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
# For many S3-compatible providers (e.g., R2) path-style is often required.
OBJECT_STORAGE_FORCE_PATH_STYLE=true

# 未上传图片的商品显示的默认图路径，对应后端 public 目录（如 public/products/default.jpg 即 /products/default.jpg）
# DEFAULT_PRODUCT_IMAGE_PATH=/products/default.jpg

# ========== Web Push（课前提醒，可选）==========
# 生成：npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# 合规联系地址，建议 mailto: 你的邮箱
# VAPID_SUBJECT=mailto:you@example.com
# 与课表查询周次一致（Schedule 页当前为固定周；提醒任务用此环境变量，默认 1）
# CLASS_REMINDER_WEEK=1

# 邮件发送（二选一）
# 方案 A - Resend API（推荐生产/ Railway）：走 HTTPS，无 SMTP 端口限制。见 .env.resend.example
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=Dorm <onboarding@resend.dev>
# 方案 B - SMTP（本地/自建）：见 .env.smtp.example
# SMTP_HOST=... SMTP_USER=... SMTP_PASS=... SMTP_FROM=...
